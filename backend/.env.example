# App
PORT=5000
ENVIRONMENT=development

# Swagger
SWAGGER_PATH=documentation

# Security
# Comma-separated client IDs accepted by ingestion endpoints.
# API keys are mapped by position:
# - AUDIT_TRAIL_CLIENT_IDS=orders-api,crm-api
# - AUDIT_TRAIL_API_KEYS=orders-secret,crm-secret
# - POST /v1/audit-events
# - POST /v1/request-logs
AUDIT_TRAIL_CLIENT_IDS=
AUDIT_TRAIL_API_KEYS=
AUDIT_TRAIL_SIGNATURE_TOLERANCE_SECONDS=300

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=audit_trail
DB_LOGGING=false
DB_SSL=false

# CORS (comma separated origins)
CORS_ORIGINS=http://localhost:3000
